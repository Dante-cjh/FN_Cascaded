# Copy this file to .env and fill in your real key.
# .env is listed in .gitignore and will never be committed.
#
# Usage:
#   cp .env.example .env
#   # then edit .env and set your key
#
# The three LLM scripts (05 / 07 / 07_run) automatically read LLM_API_KEY
# from the environment (or from a .env file if python-dotenv is installed).

LLM_API_KEY=sk-your-real-key-here
